---
import Landing from './Landing.astro';
interface Props { active: string; email?: string | null; tier: string; title?: string }
const { active, email, tier, title } = Astro.props;

const nav = [
  { group: 'Data Analysis', items: [
    { key: 'reports', label: 'Reports', href: '/dashboard' },
  ] },
  { group: 'Outreach', items: [
    { key: 'templates', label: 'Templates', href: '/dashboard/outreach/templates' },
    { key: 'campaigns', label: 'Campaigns', href: '/dashboard/outreach/campaigns' },
    { key: 'inbox', label: 'Inbox', href: '/dashboard/outreach/inbox' },
  ] },
];
---
<Landing title={title ?? 'Dashboard — Table Intelligence'}>
  <div class="dash">
    <aside class="sidebar">
      <a href="/" class="d-brand">▚ Table Intelligence</a>
      <nav class="d-nav">
        {nav.map((g) => (
          <div class="navgroup">
            <p class="navgroup-t">{g.group}</p>
            {g.items.map((it) => (
              <a href={it.href} class={active === it.key ? 'navlink on' : 'navlink'}>{it.label}</a>
            ))}
          </div>
        ))}
      </nav>
      <div class="side-foot">
        <div class="side-acct">
          <span class="side-email">{email}</span>
          <span class={`plan plan-${tier}`}>{tier}</span>
        </div>
        {tier !== 'paid' && <a href="/pricing" class="side-up">Upgrade to premium</a>}
        <div class="side-links">
          <a href="/dashboard/account" class={active === 'account' ? 'on' : ''}>Account &amp; API key</a>
          <a href="#" id="side-logout">Log out</a>
        </div>
      </div>
    </aside>
    <main class="dash-main"><slot /></main>
  </div>

  <script is:inline>
    document.getElementById('side-logout')?.addEventListener('click', async (e) => {
      e.preventDefault(); await fetch('/api/auth/logout', { method: 'POST' }); location.href = '/login';
    });
  </script>

  <style>
    .dash { display: grid; grid-template-columns: 236px 1fr; min-height: 100vh; }
    .sidebar {
      border-right: 1px solid var(--border); padding: 1.4rem 1.1rem; display: flex; flex-direction: column;
      gap: 1.5rem; position: sticky; top: 0; height: 100vh; background: var(--bg-soft);
    }
    .d-brand { font-weight: 700; color: var(--fg); }
    .d-brand:hover { text-decoration: none; }
    .d-nav { display: grid; gap: 1.2rem; }
    .navgroup-t { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); font-weight: 700; margin: 0 0 0.4rem; }
    .navlink { display: block; padding: 0.4rem 0.6rem; border-radius: 8px; color: var(--muted); font-size: 0.94rem; }
    .navlink:hover { color: var(--fg); background: color-mix(in srgb, var(--accent) 8%, transparent); text-decoration: none; }
    .navlink.on { color: var(--fg); background: color-mix(in srgb, var(--accent) 14%, transparent); font-weight: 600; }
    .side-foot { margin-top: auto; display: grid; gap: 0.6rem; font-size: 0.85rem; }
    .side-acct { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .side-email { color: var(--muted); font-size: 0.8rem; overflow: hidden; text-overflow: ellipsis; }
    .plan { text-transform: uppercase; font-size: 0.6rem; font-weight: 700; padding: 0.1rem 0.4rem; border-radius: 999px; border: 1px solid var(--border); color: var(--muted); }
    .plan.plan-trial, .plan.plan-paid { color: var(--accent); border-color: var(--accent); }
    .side-up { font-size: 0.82rem; font-weight: 600; }
    .side-links { display: flex; flex-direction: column; gap: 0.3rem; }
    .side-links a { color: var(--muted); }
    .side-links a.on { color: var(--fg); font-weight: 600; }
    .dash-main { padding: 2.2rem 2.4rem 5rem; max-width: 1000px; }
    @media (max-width: 760px) {
      .dash { grid-template-columns: 1fr; }
      .sidebar { position: static; height: auto; flex-direction: row; flex-wrap: wrap; align-items: center; gap: 1rem; }
      .d-nav { display: flex; flex-wrap: wrap; gap: 0.5rem; }
      .navgroup { display: flex; align-items: center; gap: 0.4rem; }
      .navgroup-t { display: none; }
      .side-foot { margin: 0; }
      .dash-main { padding: 1.5rem 1.25rem 4rem; }
    }
  </style>
</Landing>
