---
import Landing from '../../layouts/Landing.astro';
import Nav from '../Nav.astro';
const site = Astro.site?.origin ?? 'https://shubhamrandive.com';
const config = `{
  "mcpServers": {
    "table-intelligence": {
      "command": "uvx",
      "args": ["--from", "table-intelligence", "table-intelligence-mcp"],
      "env": {
        "TABINT_API_KEY": "<your api key>",
        "TABINT_CONTROL_PLANE_URL": "${site}"
      }
    }
  }
}`;

// The agents in the suite today (and what's next).
const agents = [
  {
    icon: '📊', name: 'Data Analysis', tag: 'Beta · Free',
    body: 'Profile, test, model and explain any table — cohorts, forecasting, RFM, causal inference — locally in your agent. Your data never leaves your machine.',
    href: '/docs',
  },
  {
    icon: '✉️', name: 'Outreach', tag: 'Premium',
    body: 'Your agent researches prospects, drafts personalised emails, and sends them through your own email — all reviewable on your dashboard first.',
    href: '/docs/outreach',
  },
  {
    icon: '✨', name: 'More agents', tag: 'Coming soon',
    body: 'Client research, sales & marketing helpers, and connectors to the tools you already use — added to the same install, under one subscription.',
    href: '/pricing',
  },
];

const features = [
  { icon: '🔒', title: 'Local-first & private', body: 'Analysis runs on your machine inside your agent. Your data never leaves it — we only ever see your API key.' },
  { icon: '🎯', title: 'Defensible, not confident', body: 'Every result carries a trust level and caveats. When the data can’t support the question, it declines instead of inventing a number.' },
  { icon: '🔌', title: 'One install, many skills', body: 'A single MCP server for Claude Cowork, Desktop, Code, Codex, Cursor and more. Every agent in the suite arrives through it.' },
  { icon: '📁', title: 'Your dashboard', body: 'Reports, prospects and results land on a dashboard you log into — comfortable for non-technical users, not just the terminal.' },
];

const steps = [
  { n: '1', t: 'Create an account', d: 'Sign up for the 3-day free trial and copy your API key.' },
  { n: '2', t: 'Install once', d: 'Paste one config block into your AI agent. Requires uv + Python 3.10+.' },
  { n: '3', t: 'Put the agents to work', d: 'Analyze data, research and reach prospects — in plain language.' },
  { n: '4', t: 'Review on your dashboard', d: 'See reports, prospects and status; edit and share from the web.' },
];
---
<Landing title="Table Intelligence — a suite of AI agents for your business">
  <Nav active="Home" />

  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">A growing suite of AI agents</p>
      <h1>Give your AI agent<br />real skills for your business.</h1>
      <p class="sub">Table Intelligence is a suite of AI agents — <strong>data analysis</strong>,
        <strong>outreach</strong>, and more — that plug into Claude and other agents through a
        single install. Real, defensible work: analyze your data, research and reach prospects,
        and see it all on your dashboard.</p>
      <div class="cta">
        <a href="/signup" class="btn btn-primary">Start free — 3-day trial</a>
        <a href="#agents" class="btn">See the agents</a>
      </div>
      <p class="micro muted">No card required · your data stays on your machine · works in Claude Cowork, Desktop, Code &amp; more</p>
    </div>
  </section>

  <!-- the agents -->
  <section id="agents" class="wrap block">
    <h2 class="center">The suite</h2>
    <p class="center sub-lead muted">One subscription, one install. New agents show up in the same place.</p>
    <div class="grid grid-3">
      {agents.map((a) => (
        <a class="agent" href={a.href}>
          <div class="ic">{a.icon}</div>
          <div class="agent-h"><h3>{a.name}</h3><span class="pill">{a.tag}</span></div>
          <p class="muted">{a.body}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- features -->
  <section class="band">
    <div class="wrap block">
      <div class="grid grid-4">
        {features.map((f) => (
          <div class="card">
            <div class="ic">{f.icon}</div>
            <h3>{f.title}</h3>
            <p class="muted">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- trust differentiator -->
  <section class="wrap block">
    <h2>Why "trust level" matters</h2>
    <p class="lead">You use these agents <em>because</em> you can't run the work yourself — which means
      you also can't check the number. So every result is honest about its own limits, and refuses
      when the data can't support the claim.</p>
    <div class="demo">
      <pre><code>{`{
  "method": "causal_effect_declined",
  "declined": true,
  "trust": { "level": "none",
    "decline_reason": "Only 18 rows — far too few to support a
      credible causal estimate (need at least 50)." }
}`}</code></pre>
      <p class="muted">A refusal is a stronger trust signal than a confident, meaningless number.</p>
    </div>
  </section>

  <!-- how it works -->
  <section class="band">
    <div class="wrap block">
      <h2 class="center">How it works</h2>
      <div class="steps">
        {steps.map((s) => (
          <div class="step">
            <div class="num">{s.n}</div>
            <div><h3>{s.t}</h3><p class="muted">{s.d}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- install -->
  <section id="install" class="wrap block">
    <h2>Install once — get every agent</h2>
    <p class="muted">Add this to your MCP client (Claude Cowork, Desktop, Code, Codex, Cursor…),
      pasting the API key from your account:</p>
    <pre><code>{config}</code></pre>
    <p><a href="/docs">Full documentation &amp; per-client guides →</a></p>
  </section>

  <footer class="foot">
    <div class="wrap foot-row">
      <span class="muted">Table Intelligence — built by <a href="/about">Shubham Randive</a></span>
      <nav class="foot-links">
        <a href="/about">About</a>
        <a href="/blog">Blog</a>
        <a href="/docs">Docs</a>
        <a href="/pricing">Pricing</a>
        <a href="/signup">Sign up</a>
      </nav>
    </div>
  </footer>
</Landing>

<style>
  .hero { padding: 4.5rem 0 3rem; text-align: center; }
  .eyebrow { text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.78rem; font-weight: 600; color: var(--accent); margin: 0 0 1rem; }
  .hero h1 { font-size: clamp(2.1rem, 6vw, 3.3rem); line-height: 1.08; letter-spacing: -0.02em; margin: 0 0 1.2rem; }
  .sub { max-width: 640px; margin: 0 auto 1.8rem; font-size: 1.12rem; color: var(--muted); }
  .sub strong { color: var(--fg); }
  .cta { display: flex; gap: .7rem; justify-content: center; flex-wrap: wrap; }
  .micro { font-size: 0.82rem; margin-top: 1.4rem; }

  .block { padding: 3.25rem 1.25rem; }
  h2 { font-size: 1.7rem; letter-spacing: -0.01em; }
  .center { text-align: center; }
  .sub-lead { margin: 0 auto 2rem; max-width: 40rem; }

  .grid { display: grid; gap: 1rem; }
  .grid-3 { grid-template-columns: repeat(3, 1fr); }
  .grid-4 { grid-template-columns: repeat(4, 1fr); }
  .card { border: 1px solid var(--border); border-radius: 12px; padding: 1.3rem; background: var(--bg); }
  .card h3 { margin: .1rem 0 .4rem; font-size: 1.05rem; }
  .card p { margin: 0; font-size: 0.93rem; }
  .ic { font-size: 1.5rem; margin-bottom: .5rem; }

  .agent { display: block; border: 1px solid var(--border); border-radius: 14px; padding: 1.4rem; background: var(--bg); color: var(--fg); transition: border-color .15s, transform .15s; }
  .agent:hover { border-color: var(--accent); text-decoration: none; transform: translateY(-2px); }
  .agent-h { display: flex; align-items: center; gap: .6rem; flex-wrap: wrap; margin-bottom: .4rem; }
  .agent-h h3 { margin: 0; font-size: 1.1rem; }
  .agent p { margin: 0; font-size: 0.93rem; }
  .pill { font-size: 0.66rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; color: var(--accent); border: 1px solid var(--accent); border-radius: 999px; padding: .12rem .5rem; }

  .band { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--bg-soft); }
  .lead { max-width: 640px; font-size: 1.08rem; color: var(--muted); }
  .lead em { color: var(--fg); font-style: normal; font-weight: 600; }
  .demo { margin-top: 1.4rem; }
  .demo pre { max-width: 560px; }

  .steps { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.4rem 2rem; max-width: 820px; margin: 0 auto; }
  .step { display: flex; gap: .9rem; }
  .num { flex: none; width: 34px; height: 34px; border-radius: 50%; background: var(--accent); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; }
  .step h3 { margin: .2rem 0 .3rem; font-size: 1.05rem; }
  .step p { margin: 0; font-size: 0.95rem; }

  .foot { border-top: 1px solid var(--border); padding: 2rem 0; }
  .foot-row { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .8rem; font-size: 0.92rem; }
  .foot-links { display: flex; gap: 1.1rem; }
  .foot-links a { color: var(--muted); }

  @media (max-width: 780px) {
    .grid-3, .grid-4 { grid-template-columns: 1fr 1fr; }
    .steps { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) {
    .grid-3, .grid-4 { grid-template-columns: 1fr; }
  }
</style>
