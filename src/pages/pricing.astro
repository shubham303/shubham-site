---
import Layout from '../layouts/Layout.astro';
export const prerender = false;
---
<Layout title="Pricing — Table Intelligence">
  <h1>Pricing</h1>
  <p>Start with a <strong>3-day free trial</strong> (no card). Then premium.</p>
  <h2>Free</h2>
  <ul>
    <li>All analytics tools — run locally in your AI agent, forever</li>
    <li>Your data never leaves your machine</li>
  </ul>
  <h2>Premium</h2>
  <ul>
    <li>Everything in Free</li>
    <li>Save &amp; organize reports into folders</li>
    <li>Web dashboard to access and share reports</li>
  </ul>
  <p style="margin-top:1.5rem"><a href="/signup"
    style="display:inline-block;padding:.55rem 1rem;border:1px solid var(--accent);background:var(--accent);color:#fff;border-radius:6px">Start free trial →</a></p>
  <p><small>Payments via Razorpay (coming). During the trial you get full premium access.</small></p>
</Layout>
