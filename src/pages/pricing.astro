---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
export const prerender = false;
---
<Layout title="Pricing — Table Intelligence">
  <Nav active="Pricing" />
  <div class="pricing">
    <div class="ph">
      <span class="beta">Beta</span>
      <h1>Simple pricing</h1>
      <p class="ph-sub">
        One plan. <strong>$5/month</strong>, starting with a <strong>3-day free trial</strong> — no card
        required. Table Intelligence is in beta; early users keep this price.
      </p>
    </div>

    <div class="tiers">
      <div class="tier">
        <h2>Free</h2>
        <p class="price"><span class="amt">$0</span></p>
        <p class="tier-for">Run analytics locally, forever.</p>
        <ul class="feat">
          <li>All analytics tools in your AI agent</li>
          <li>Your raw data never leaves your machine</li>
          <li>Unlimited local analyses</li>
        </ul>
        <a class="btn ghost" href="/docs/install">Install &amp; start free →</a>
      </div>

      <div class="tier featured">
        <div class="ribbon">3-day free trial</div>
        <h2>Premium</h2>
        <p class="price"><span class="amt">$5</span><span class="per">/month</span></p>
        <p class="tier-for">Everything in Free, plus the cloud + connectors.</p>
        <ul class="feat">
          <li><strong>Save &amp; share reports</strong> to your dashboard</li>
          <li><strong>Outreach connector</strong> — research, draft &amp; send from your agent</li>
          <li>Organize into folders; public share links</li>
          <li>Use on up to <strong>2 devices</strong></li>
          <li>New connectors as they launch</li>
        </ul>
        <a class="btn" href="/signup">Start free trial →</a>
      </div>
    </div>

    <section class="servers">
      <h2>What's available today</h2>
      <p class="servers-sub">The platform is one MCP server your agent installs, with a growing set of
        capabilities. Two are live right now:</p>
      <div class="srow">
        <div class="scard">
          <div class="scard-h">
            <strong>Table Intelligence — Analytics</strong>
            <span class="tag beta-tag">Beta</span>
            <span class="tag free-tag">Free</span>
          </div>
          <p>Profile, test, model and explain any table locally — profiling, correlations, forecasting,
            RFM, cohorts, causal checks. Runs on your machine; nothing is uploaded.</p>
        </div>
        <div class="scard">
          <div class="scard-h">
            <strong>Outreach</strong>
            <span class="tag paid-tag">Premium</span>
          </div>
          <p>Your agent researches prospects, drafts personalised emails, and sends them through your own
            email — all reviewable on your dashboard first. <a href="/docs/agents/outreach">How it works →</a></p>
        </div>
      </div>
    </section>

    <p class="note"><small>Payments via Razorpay. During the trial you get full premium access; cancel
      anytime. As a beta product, features and limits may still change — early feedback shapes them.</small></p>
  </div>

  <style>
    .pricing { max-width: 760px; margin: 0 auto; }
    .ph { text-align: center; margin-bottom: 2rem; }
    .beta {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 999px;
      padding: 0.15rem 0.6rem;
      margin-bottom: 0.75rem;
    }
    .ph h1 { font-size: 1.9rem; margin: 0 0 0.5rem; }
    .ph-sub { color: var(--muted); max-width: 34rem; margin: 0 auto; }

    .tiers { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 620px) { .tiers { grid-template-columns: 1fr; } }
    .tier {
      position: relative;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.6rem 1.4rem;
      background: var(--bg);
    }
    .tier.featured {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px var(--accent);
    }
    .ribbon {
      position: absolute;
      top: -0.7rem;
      right: 1rem;
      background: var(--accent);
      color: #fff;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
    }
    .tier h2 { font-size: 1.1rem; margin: 0 0 0.4rem; }
    .price { margin: 0 0 0.2rem; }
    .price .amt { font-size: 2.1rem; font-weight: 700; }
    .price .per { color: var(--muted); font-size: 0.95rem; }
    .tier-for { color: var(--muted); font-size: 0.9rem; margin: 0 0 1rem; }
    .feat { list-style: none; padding: 0; margin: 0 0 1.4rem; display: grid; gap: 0.5rem; }
    .feat li { position: relative; padding-left: 1.5rem; font-size: 0.92rem; }
    .feat li::before {
      content: '✓'; position: absolute; left: 0; color: var(--accent); font-weight: 700;
    }
    .btn {
      display: block;
      text-align: center;
      padding: 0.6rem;
      border: 1px solid var(--accent);
      background: var(--accent);
      color: #fff;
      border-radius: 8px;
      font-weight: 600;
    }
    .btn:hover { opacity: 0.92; text-decoration: none; }
    .btn.ghost { background: var(--bg); color: var(--accent); }

    .servers { margin-top: 2.75rem; }
    .servers h2 { font-size: 1.25rem; margin: 0 0 0.3rem; }
    .servers-sub { color: var(--muted); font-size: 0.92rem; margin: 0 0 1rem; }
    .srow { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 620px) { .srow { grid-template-columns: 1fr; } }
    .scard { border: 1px solid var(--border); border-radius: 12px; padding: 1.1rem 1.2rem; }
    .scard p { font-size: 0.9rem; color: var(--muted); margin: 0.5rem 0 0; }
    .scard-h { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .tag {
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;
      padding: 0.12rem 0.45rem; border-radius: 999px; border: 1px solid var(--border);
    }
    .beta-tag { color: var(--accent); border-color: var(--accent); }
    .free-tag { color: var(--muted); }
    .paid-tag { color: #fff; background: var(--accent); border-color: var(--accent); }
    .note { text-align: center; color: var(--muted); margin-top: 2rem; }
  </style>
</Layout>
