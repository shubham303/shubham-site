---
import { platformHomeEnabled } from '@server/lib/flags';
import PlatformHome from '../components/home/PlatformHome.astro';
import PersonalHome from '../components/home/PersonalHome.astro';
export const prerender = false;

// Feature flag: PLATFORM_HOME=true makes / the platform landing.
// Default (off) keeps the original personal homepage in production.
const showPlatform = platformHomeEnabled();
---
{showPlatform ? <PlatformHome /> : <PersonalHome />}
