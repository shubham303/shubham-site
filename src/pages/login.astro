---
import Layout from '../layouts/Layout.astro';
export const prerender = false;
---
<Layout title="Log in — Table Intelligence">
  <div class="auth">
    <div class="auth-card">
      <p class="auth-brand">Table Intelligence</p>
      <h1>Welcome back</h1>
      <p class="auth-sub">Log in to your dashboard, reports, and outreach.</p>

      <form id="f" class="auth-form">
        <div class="field">
          <label for="email">Email</label>
          <input id="email" type="email" autocomplete="email" placeholder="you@example.com" required />
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input id="password" type="password" autocomplete="current-password" placeholder="••••••••" required />
        </div>
        <button type="submit" id="submit">Log in</button>
      </form>

      <p id="msg" class="auth-msg"></p>
    </div>
    <p class="auth-alt"><small>No account? <a href="/signup">Start a free trial</a></small></p>
  </div>

  <script is:inline>
    const f = document.getElementById('f');
    const btn = document.getElementById('submit');
    f.addEventListener('submit', async (e) => {
      e.preventDefault();
      document.getElementById('msg').textContent = '';
      btn.disabled = true; btn.textContent = 'Logging in…';
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      // BetterAuth sign-in endpoint (served by /api/auth/[...all]). The cookie
      // is set automatically on success.
      const r = await fetch('/api/auth/sign-in/email', {
        method: 'POST', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });
      const d = await r.json().catch(() => ({}));
      if (!r.ok) {
        document.getElementById('msg').textContent = d?.message || d?.error || 'Login failed.';
        btn.disabled = false; btn.textContent = 'Log in';
        return;
      }
      location.href = '/table-intelligence';
    });
  </script>

  <style>
    .auth { max-width: 400px; margin: 1.5rem auto 0; }
    .auth-card {
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 2rem 1.75rem 1.75rem;
      background: var(--bg);
      box-shadow: 0 1px 3px rgba(20, 25, 40, 0.05);
    }
    .auth-brand {
      margin: 0 0 1rem;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .auth h1 { font-size: 1.5rem; margin: 0 0 0.3rem; }
    .auth-sub { margin: 0 0 1.5rem; color: var(--muted); font-size: 0.95rem; }
    .auth-form { display: grid; gap: 1rem; }
    .field { display: grid; gap: 0.3rem; }
    .field label { font-size: 0.8rem; font-weight: 600; color: var(--muted); }
    .field input {
      padding: 0.6rem 0.7rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg);
      color: var(--fg);
      font-size: 0.95rem;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .field input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 22%, transparent);
    }
    .auth button {
      margin-top: 0.25rem;
      padding: 0.65rem;
      border: 1px solid var(--accent);
      background: var(--accent);
      color: #fff;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.15s;
    }
    .auth button:hover { opacity: 0.92; }
    .auth button:disabled { opacity: 0.6; cursor: default; }
    .auth-msg { color: #cf222e; font-size: 0.88rem; min-height: 1.1rem; margin: 0.9rem 0 0; }
    .auth-alt { text-align: center; margin-top: 1.25rem; color: var(--muted); }
  </style>
</Layout>
