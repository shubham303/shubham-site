---
import Layout from '../../layouts/Layout.astro';
import DashboardHeader from '../../components/DashboardHeader.astro';
import { ensureInit, getProvider } from '@server/db/factory';
import { verifySession, SESSION_COOKIE } from '@server/lib/session';
import { tierForUser } from '@server/services/entitlementService';
import { listFolders, listReports } from '@server/services/reportService';

export const prerender = false;

await ensureInit();
const uid = verifySession(Astro.cookies.get(SESSION_COOKIE)?.value);
if (!uid) return Astro.redirect('/login');
const user = await getProvider().users.getById(uid);
const tier = await tierForUser(uid);
const folders = await listFolders(uid);
const reports = await listReports(uid);

const fmt = (d: string) => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<Layout title="Dashboard — Table Intelligence">
  <DashboardHeader email={user?.email} tier={tier} active="Reports" />

  <div class="row">
    <h1>Reports</h1>
    <span class="count">{reports.length}</span>
  </div>

  {reports.length === 0 ? (
    <div class="empty">
      <p>No reports yet.</p>
      <p class="muted">In your AI agent, run an analysis with Table Intelligence and ask it to
        <em>save a report</em> — it'll show up here.</p>
    </div>
  ) : (
    <ul class="cards">
      {reports.map((r) => (
        <li class="rcard">
          <a class="rcard-title" href={`/dashboard/reports/${r.id}`}>{r.title}</a>
          <div class="rcard-meta">
            <span>{fmt(r.created_at)}</span>
            {r.folder_id && <span class="chip">in folder</span>}
            {r.shared && <span class="chip chip-accent">shared</span>}
          </div>
        </li>
      ))}
    </ul>
  )}

  <section class="folders">
    <div class="row">
      <h2>Folders</h2>
      <span class="count">{folders.length}</span>
    </div>
    {folders.length > 0 && (
      <ul class="chips-row">{folders.map((f) => <li class="chip">{f.name}</li>)}</ul>
    )}
    <form id="nf" class="nf">
      <input id="fname" placeholder="New folder name" />
      <button>Create</button>
    </form>
  </section>

  <script is:inline>
    document.getElementById('nf').addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('fname').value;
      if (!name) return;
      await fetch('/api/folders', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ name }) });
      location.reload();
    });
  </script>

  <style>
    .row { display: flex; align-items: baseline; gap: 0.6rem; margin: 0 0 1rem; }
    .row h1, .row h2 { margin: 0; }
    .count {
      font-size: 0.75rem; font-weight: 700; color: var(--muted);
      border: 1px solid var(--border); border-radius: 999px; padding: 0.05rem 0.5rem;
    }
    .muted { color: var(--muted); }
    .empty { border: 1px dashed var(--border); border-radius: 12px; padding: 1.5rem; }
    .empty p { margin: 0 0 0.4rem; }
    .cards { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.7rem; }
    .rcard {
      border: 1px solid var(--border); border-radius: 12px; padding: 1rem 1.1rem;
      transition: border-color 0.15s;
    }
    .rcard:hover { border-color: var(--accent); }
    .rcard-title { font-size: 1.05rem; font-weight: 600; }
    .rcard-meta { display: flex; gap: 0.5rem; align-items: center; margin-top: 0.35rem; font-size: 0.83rem; color: var(--muted); }
    .chip {
      font-size: 0.72rem; padding: 0.1rem 0.5rem; border: 1px solid var(--border);
      border-radius: 999px; color: var(--muted); list-style: none;
    }
    .chip-accent { color: var(--accent); border-color: var(--accent); }
    .folders { margin-top: 2.5rem; }
    .chips-row { display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0; margin: 0 0 1rem; }
    .nf { display: flex; gap: 0.4rem; max-width: 360px; }
    .nf input {
      flex: 1; padding: 0.45rem 0.6rem; border: 1px solid var(--border); border-radius: 8px;
      background: var(--bg); color: var(--fg);
    }
    .nf input:focus { outline: none; border-color: var(--accent); }
    .nf button {
      padding: 0.45rem 0.8rem; border: 1px solid var(--border); border-radius: 8px;
      background: var(--bg); color: var(--fg); cursor: pointer;
    }
    .nf button:hover { border-color: var(--accent); }
  </style>
</Layout>
