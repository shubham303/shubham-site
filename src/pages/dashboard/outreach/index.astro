---
import Layout from '../../../layouts/Layout.astro';
import DashboardHeader from '../../../components/DashboardHeader.astro';
import { ensureInit, getProvider } from '@server/db/factory';
import { verifySession, SESSION_COOKIE } from '@server/lib/session';
import { tierForUser } from '@server/services/entitlementService';
import { listPrompts, listProspects } from '@server/services/outreachService';
import { getEmailAccount } from '@server/services/emailService';

export const prerender = false;

await ensureInit();
const uid = verifySession(Astro.cookies.get(SESSION_COOKIE)?.value);
if (!uid) return Astro.redirect('/login');
const user = await getProvider().users.getById(uid);
const tier = await tierForUser(uid);
const prompts = await listPrompts(uid);
const prospects = await listProspects(uid);
const email = await getEmailAccount(uid);
const entitled = tier === 'paid' || tier === 'trial';
---
<Layout title="Outreach — Table Intelligence">
  <DashboardHeader email={user?.email} tier={tier} active="Outreach" />

  {!entitled && (
    <div class="banner">
      Outreach is a premium connector. <a href="/pricing">Start a trial or upgrade</a> to use it.
    </div>
  )}

  <!-- sending email -->
  <section>
    <div class="row"><h2>Sending email</h2>
      {email.connected && <span class="badge badge-ok">connected</span>}
    </div>
    {email.connected ? (
      <p class="muted">Sending as <strong>{email.from_email}</strong> via {email.provider}.</p>
    ) : (
      <p class="muted">Connect your own Resend account — email sends from your domain, replies come to you.</p>
    )}
    <form id="ef" class="ef">
      <input id="from_email" placeholder="From email (your verified domain)" />
      <input id="from_name" placeholder="From name (optional)" />
      <input id="api_key" type="password" placeholder="Resend API key (rk_…)" />
      <button>{email.connected ? 'Update sending account' : 'Save sending account'}</button>
    </form>
  </section>

  <!-- prompts -->
  <section class="mt">
    <div class="row"><h2>Prompts</h2><span class="count">{prompts.length}</span></div>
    {prompts.length === 0 ? (
      <p class="muted">No outreach prompts yet. Ask your AI agent to create one.</p>
    ) : (
      <ul class="chips-row">{prompts.map((p) => <li class="chip">{p.name}</li>)}</ul>
    )}
  </section>

  <!-- prospects -->
  <section class="mt">
    <div class="row"><h2>Prospects</h2><span class="count">{prospects.length}</span></div>
    {prospects.length === 0 ? (
      <p class="muted">No prospects yet. In your AI agent, ask Table Intelligence to research prospects
        and draft outreach — they'll appear here to review before you send.</p>
    ) : (
      <div class="tblwrap">
        <table class="tbl">
          <thead><tr><th>Name</th><th>Email</th><th>Status</th><th></th></tr></thead>
          <tbody>
            {prospects.map((p) => (
              <tr>
                <td><span class="pname">{p.name || '—'}</span>{p.company && <span class="pcompany">{p.company}</span>}</td>
                <td class="pemail">{p.email || '—'}</td>
                <td><span class={`badge badge-${p.status}`}>{p.status}</span></td>
                <td class="right">
                  {p.status !== 'sent' && p.status !== 'replied' && (
                    <button class="send" data-id={p.id}>Send</button>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>

  <script is:inline>
    document.getElementById('ef').addEventListener('submit', async (e) => {
      e.preventDefault();
      const payload = {
        from_email: document.getElementById('from_email').value,
        from_name: document.getElementById('from_name').value,
        api_key: document.getElementById('api_key').value,
      };
      const r = await fetch('/api/outreach/email-account', {
        method: 'PUT', headers: { 'content-type': 'application/json' }, body: JSON.stringify(payload),
      });
      if (r.ok) location.reload();
      else alert('Could not save — check the fields.');
    });
    document.querySelectorAll('.send').forEach((btn) => {
      btn.addEventListener('click', async () => {
        btn.disabled = true; btn.textContent = 'Sending…';
        const r = await fetch(`/api/outreach/prospects/${btn.dataset.id}/send`, { method: 'POST' });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) { location.reload(); }
        else { btn.disabled = false; btn.textContent = 'Send'; alert(d.message || 'Send failed.'); }
      });
    });
  </script>

  <style>
    .row { display: flex; align-items: baseline; gap: 0.6rem; margin: 0 0 0.7rem; }
    .row h2 { margin: 0; }
    .mt { margin-top: 2.25rem; }
    .muted { color: var(--muted); font-size: 0.92rem; }
    .count, .badge {
      font-size: 0.72rem; font-weight: 700; padding: 0.08rem 0.5rem; border-radius: 999px;
      border: 1px solid var(--border); color: var(--muted);
    }
    .badge { text-transform: uppercase; letter-spacing: 0.03em; font-size: 0.66rem; }
    .banner { padding: 0.7rem 0.9rem; border: 1px solid var(--accent); border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.92rem; }
    .ef { display: grid; gap: 0.5rem; max-width: 420px; margin-top: 0.6rem; }
    .ef input {
      padding: 0.5rem 0.6rem; border: 1px solid var(--border); border-radius: 8px;
      background: var(--bg); color: var(--fg);
    }
    .ef input:focus { outline: none; border-color: var(--accent); }
    .ef button {
      padding: 0.5rem; border: 1px solid var(--border); border-radius: 8px;
      background: var(--bg); color: var(--fg); cursor: pointer; font-weight: 500;
    }
    .ef button:hover { border-color: var(--accent); }
    .chips-row { display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0; margin: 0; list-style: none; }
    .chip { font-size: 0.85rem; padding: 0.25rem 0.7rem; border: 1px solid var(--border); border-radius: 999px; }
    .tblwrap { overflow-x: auto; }
    .tbl { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .tbl th { text-align: left; color: var(--muted); font-weight: 600; font-size: 0.8rem; padding: 0.5rem 0.6rem; border-bottom: 1px solid var(--border); }
    .tbl td { padding: 0.7rem 0.6rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
    .pname { font-weight: 600; display: block; }
    .pcompany { color: var(--muted); font-size: 0.82rem; }
    .pemail { color: var(--muted); }
    .right { text-align: right; }
    .send {
      padding: 0.3rem 0.7rem; border: 1px solid var(--accent); background: var(--accent); color: #fff;
      border-radius: 7px; cursor: pointer; font-size: 0.85rem; font-weight: 600;
    }
    .send:hover { filter: brightness(1.05); }
    .send:disabled { opacity: 0.6; cursor: default; }
    /* status colors */
    .badge-new { color: var(--muted); }
    .badge-drafted { color: #9a6700; border-color: #9a6700; }
    .badge-sent { color: var(--accent); border-color: var(--accent); }
    .badge-delivered { color: var(--accent); border-color: var(--accent); }
    .badge-replied, .badge-ok { color: #1a7f37; border-color: #1a7f37; }
    .badge-bounced { color: #cf222e; border-color: #cf222e; }
  </style>
</Layout>
