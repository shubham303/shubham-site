---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Layout title="Blog — Shubham Randive" description="Writing on data science, AI agents, and building products.">
  <Nav active="Blog" />
  <header class="blog-head">
    <h1>Blog</h1>
    <p class="muted">Thinking out loud about data science, AI agents, and building things that ship.</p>
  </header>

  {posts.length === 0 ? (
    <p class="muted">Posts coming soon.</p>
  ) : (
    <ul class="posts">
      {posts.map((post) => (
        <li class="post">
          <div class="post-top">
            <a class="post-title" href={`/blog/${post.id}/`}>{post.data.title}</a>
            <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
          </div>
          {post.data.description && <p class="post-desc muted">{post.data.description}</p>}
        </li>
      ))}
    </ul>
  )}
</Layout>

<style>
  .blog-head { margin: 2rem 0 1.5rem; }
  .blog-head h1 { margin: 0 0 0.4rem; font-size: 1.95rem; }
  .muted { color: var(--muted); }
  .posts { list-style: none; padding: 0; margin: 0; }
  .post { padding: 1.1rem 0; border-bottom: 1px solid var(--border); }
  .post-top { display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; }
  .post-title { font-size: 1.1rem; font-weight: 600; }
  .post-top time { color: var(--muted); font-size: 0.88rem; white-space: nowrap; }
  .post-desc { margin: 0.35rem 0 0; font-size: 0.95rem; }
</style>
