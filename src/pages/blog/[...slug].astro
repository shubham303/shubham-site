---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection, render } from 'astro:content';

// Server-rendered (not prerendered) so the shared Nav can read auth state.
// The rest of the site is SSR-first; Vercel caches the rendered output.
export const prerender = false;

const slug = Astro.params.slug as string;
const posts = await getCollection('blog');
const post = posts.find((p) => p.id === slug);
if (!post) return new Response('Not found', { status: 404 });
const { Content } = await render(post);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Layout title={post.data.title} description={post.data.description}>
  <Nav minimal />
  <article>
    <h1>{post.data.title}</h1>
    <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
    <div class="content">
      <Content />
    </div>
  </article>
</Layout>

<style>
  article h1 {
    margin-bottom: 0.35rem;
  }
  time {
    color: var(--muted);
    font-size: 0.9em;
  }
  .content {
    margin-top: 1.75rem;
  }
  .content :global(h2) {
    margin-top: 2rem;
  }
</style>
