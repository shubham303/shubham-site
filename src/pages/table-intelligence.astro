---
import Landing from '../layouts/Landing.astro';
export const prerender = false;
const site = Astro.site?.origin ?? 'https://shubhamrandive.com';
const config = `{
  "mcpServers": {
    "table-intelligence": {
      "command": "uvx",
      "args": ["--from", "table-intelligence", "table-intelligence-mcp"],
      "env": {
        "TABINT_API_KEY": "<your api key>",
        "TABINT_CONTROL_PLANE_URL": "${site}"
      }
    }
  }
}`;

const features = [
  { icon: '🔒', title: 'Local-first & private', body: 'Analysis runs on your machine inside your agent. Your data never leaves it — we only ever see your API key.' },
  { icon: '🎯', title: 'Defensible, not confident', body: 'Every result carries a trust level and caveats. When the data can’t support the question, it declines instead of inventing a number.' },
  { icon: '🧠', title: 'Real data science', body: 'RFM, cohorts, retention, forecasting, classification, association mining and causal inference — deterministic, reproducible math.' },
  { icon: '🔌', title: 'Works in your agent', body: 'A single MCP server for Claude Cowork, Claude Desktop, Claude Code, Codex, Cursor and more. One install.' },
  { icon: '📁', title: 'Reports & folders', body: 'Ask your agent to save a report. Organize into folders and read them anytime on your dashboard.' },
  { icon: '🔗', title: 'Share a link', body: 'Turn any saved report into a clean public link to send to a client or teammate.' },
];

const steps = [
  { n: '1', t: 'Create an account', d: 'Sign up for the 3-day free trial and copy your API key.' },
  { n: '2', t: 'Install the MCP server', d: 'Paste one config block into your AI agent. Requires uv + Python 3.10+.' },
  { n: '3', t: 'Analyze your data', d: 'Give it a CSV and ask real questions — trends, churn, causes.' },
  { n: '4', t: 'Save & share reports', d: 'Save findings to your account and view them on the dashboard.' },
];
---
<Landing title="Table Intelligence — real data analysis inside your AI agent">
  <!-- header -->
  <header class="nav">
    <div class="wrap nav-row">
      <a href="/table-intelligence" class="brand">▚ Table Intelligence</a>
      <nav class="nav-links">
        <a href="/docs">Docs</a>
        <a href="/pricing">Pricing</a>
        <a href="/login">Sign in</a>
        <a href="/signup" class="btn btn-primary btn-sm">Start free</a>
      </nav>
    </div>
  </header>

  <!-- hero -->
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Data science as an MCP server</p>
      <h1>Ask one question.<br />Get analysis you can defend.</h1>
      <p class="sub">Table Intelligence brings real, reproducible data science into your AI agent —
        cohorts, forecasting, causal inference and more. It runs <strong>locally</strong>, so your
        data never leaves your machine, and every answer comes with how much to trust it.</p>
      <div class="cta">
        <a href="/signup" class="btn btn-primary">Start free — 3-day trial</a>
        <a href="#install" class="btn">Install guide</a>
      </div>
      <p class="micro muted">No card required · your data stays on your machine · works in Claude Cowork, Desktop, Code & more</p>
    </div>
  </section>

  <!-- features -->
  <section class="wrap block">
    <div class="grid">
      {features.map((f) => (
        <div class="card">
          <div class="ic">{f.icon}</div>
          <h3>{f.title}</h3>
          <p class="muted">{f.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- trust differentiator -->
  <section class="band">
    <div class="wrap">
      <h2>Why "trust level" matters</h2>
      <p class="lead">You pay for this <em>because</em> you can't run it yourself — which means you also
        can't check the number. So every result is honest about its own limits, and refuses when the data
        can't support the claim.</p>
      <div class="demo">
        <pre><code>{`{
  "method": "causal_effect_declined",
  "declined": true,
  "trust": { "level": "none",
    "decline_reason": "Only 18 rows — far too few to support a
      credible causal estimate (need at least 50)." }
}`}</code></pre>
        <p class="muted">A refusal is a stronger trust signal than a confident, meaningless number.</p>
      </div>
    </div>
  </section>

  <!-- how it works -->
  <section class="wrap block">
    <h2 class="center">How it works</h2>
    <div class="steps">
      {steps.map((s) => (
        <div class="step">
          <div class="num">{s.n}</div>
          <div>
            <h3>{s.t}</h3>
            <p class="muted">{s.d}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- install -->
  <section id="install" class="band">
    <div class="wrap">
      <h2>Install in one config block</h2>
      <p class="muted">Add this to your MCP client (Claude Cowork, Desktop, Code, Codex, Cursor…),
        pasting the API key from your account:</p>
      <pre><code>{config}</code></pre>
      <p><a href="/docs">Full documentation &amp; per-client guides →</a></p>
    </div>
  </section>

  <!-- pricing teaser -->
  <section class="wrap block">
    <h2 class="center">Simple pricing</h2>
    <div class="price-grid">
      <div class="card">
        <h3>Free</h3>
        <p class="muted">All analytics tools, forever. Runs locally; your data stays put.</p>
      </div>
      <div class="card highlight">
        <h3>Premium</h3>
        <p class="muted">Everything free, plus saving &amp; organizing reports and the web dashboard.</p>
        <a href="/signup" class="btn btn-primary btn-sm">Start 3-day trial</a>
      </div>
    </div>
    <p class="center micro muted">Full premium access during your trial. <a href="/pricing">See pricing →</a></p>
  </section>

  <!-- footer -->
  <footer class="foot">
    <div class="wrap foot-row">
      <span class="muted">Table Intelligence — built by <a href="/">Shubham Randive</a></span>
      <nav class="foot-links">
        <a href="/">Profile</a>
        <a href="/docs">Docs</a>
        <a href="/pricing">Pricing</a>
        <a href="/signup">Sign up</a>
      </nav>
    </div>
  </footer>
</Landing>

<style>
  .nav { border-bottom: 1px solid var(--border); position: sticky; top: 0; background: color-mix(in srgb, var(--bg) 88%, transparent); backdrop-filter: blur(8px); z-index: 10; }
  .nav-row { display: flex; align-items: center; justify-content: space-between; height: 60px; }
  .brand { font-weight: 700; color: var(--fg); letter-spacing: -0.01em; }
  .brand:hover { text-decoration: none; }
  .nav-links { display: flex; align-items: center; gap: 1.1rem; }
  .nav-links a { color: var(--muted); font-size: 0.95rem; }
  .nav-links a:hover { color: var(--fg); text-decoration: none; }
  .btn-sm { padding: .4rem .8rem; font-size: 0.9rem; }
  .nav-links .btn-primary { color: var(--accent-fg); }

  .hero { padding: 5rem 0 3.5rem; text-align: center; }
  .eyebrow { text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.78rem; font-weight: 600; color: var(--accent); margin: 0 0 1rem; }
  .hero h1 { font-size: clamp(2.1rem, 6vw, 3.4rem); line-height: 1.08; letter-spacing: -0.02em; margin: 0 0 1.2rem; }
  .sub { max-width: 620px; margin: 0 auto 1.8rem; font-size: 1.12rem; color: var(--muted); }
  .sub strong { color: var(--fg); }
  .cta { display: flex; gap: .7rem; justify-content: center; flex-wrap: wrap; }
  .micro { font-size: 0.82rem; margin-top: 1.4rem; }

  .block { padding: 3.5rem 1.25rem; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .card { border: 1px solid var(--border); border-radius: 12px; padding: 1.3rem; background: var(--bg); }
  .card h3 { margin: .1rem 0 .4rem; font-size: 1.05rem; }
  .card p { margin: 0; font-size: 0.95rem; }
  .ic { font-size: 1.5rem; margin-bottom: .5rem; }

  .band { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--bg-soft); padding: 3.5rem 0; }
  .band .wrap > h2 { margin-top: 0; }
  .lead { max-width: 640px; font-size: 1.08rem; color: var(--muted); }
  .lead em { color: var(--fg); font-style: normal; font-weight: 600; }
  .demo { margin-top: 1.4rem; }
  .demo pre { max-width: 560px; }

  h2 { font-size: 1.7rem; letter-spacing: -0.01em; }
  .center { text-align: center; }
  .block > .center { margin-bottom: 2rem; }

  .steps { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.4rem 2rem; max-width: 820px; margin: 0 auto; }
  .step { display: flex; gap: .9rem; }
  .num { flex: none; width: 34px; height: 34px; border-radius: 50%; background: var(--accent); color: var(--accent-fg); display: inline-flex; align-items: center; justify-content: center; font-weight: 700; }
  .step h3 { margin: .2rem 0 .3rem; font-size: 1.05rem; }
  .step p { margin: 0; font-size: 0.95rem; }

  .price-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; max-width: 640px; margin: 0 auto 1rem; }
  .card.highlight { border-color: var(--accent); }
  .card.highlight .btn { margin-top: .8rem; }

  .foot { border-top: 1px solid var(--border); padding: 2rem 0; }
  .foot-row { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .8rem; font-size: 0.92rem; }
  .foot-links { display: flex; gap: 1.1rem; }
  .foot-links a { color: var(--muted); }

  @media (max-width: 780px) {
    .grid { grid-template-columns: 1fr 1fr; }
    .steps { grid-template-columns: 1fr; }
    .price-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) {
    .grid { grid-template-columns: 1fr; }
    .nav-links { gap: .7rem; }
    .nav-links a:not(.btn) { display: none; }
  }
</style>
