# Copy to .env and fill in. Both local dev and production read these.
# .env is gitignored — never commit real values.

# Neon Postgres connection string (pooled endpoint recommended).
# Neon console → project → Connect → copy the pooled URI, or:
#   npx neonctl connection-string <branch> --project-id <id> --database-name neondb --pooled
# Use the `dev` branch locally and the `main` branch in production.
# Must end with ?sslmode=require
DATABASE_URL=postgresql://neondb_owner:[PASSWORD]@ep-xxxx-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require

# BetterAuth — signs session JWTs and API keys. Any long random string.
# Generate one with:  openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string

# The public URL of this site. http://localhost:4321 in dev, your Vercel URL in prod.
BETTER_AUTH_URL=http://localhost:4321

# (Optional) Comma-separated extra origins allowed to call /api/auth/* (CORS).
# Useful if the MCP client or another first-party app calls auth endpoints.
# BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com

# Razorpay (payments) — later
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
