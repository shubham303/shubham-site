# Copy to .env and fill in. Both local dev and production read these.
# .env is gitignored — never commit real values.

# Supabase Postgres connection string (Session pooler recommended).
# Supabase dashboard → project → Connect → Session pooler → copy URI.
# Make sure it ends with ?sslmode=require
DATABASE_URL=postgresql://postgres.acjwlglurtqxkazdeehn:[YOUR-DB-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

# Secret used to sign session cookies. Any long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# Razorpay (payments) — later
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
